# ════════════════════════════════════════════
#  PolyBot — Variables d'environnement
#  Copie ce fichier en .env et remplis les valeurs
# ════════════════════════════════════════════

# ── WALLET POLYGON (OBLIGATOIRE) ──────────────
PRIVATE_KEY=ta_cle_privee_ici_sans_0x

# ── ANTHROPIC (OBLIGATOIRE pour Claude analyst) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── TRADING MODE ──────────────────────────────
# true = simulation | false = LIVE (vrais ordres)
DRY_RUN=true

# ── CAPITAL ───────────────────────────────────
BANKROLL_USDC=20

# ── RISK MANAGEMENT ───────────────────────────
MAX_POSITION_PCT=0.15
MIN_EDGE_THRESHOLD=0.06
MIN_VOLUME_24H=1000
MAX_SPREAD_PCT=0.05
MIN_PROB=0.70
MAX_PROB=0.97

# ── STRATÉGIE ─────────────────────────────────
EXPIRY_WINDOW_DAYS=7
SCAN_INTERVAL_MINUTES=15

# ── LOGS ──────────────────────────────────────
LOG_LEVEL=INFO
